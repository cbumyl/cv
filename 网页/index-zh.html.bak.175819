    <script>const navMenuBtn=document.querySelector(".nav-menu-btn"),navbar=document.querySelector(".navbar");navMenuBtn&&navbar&&(navMenuBtn.addEventListener("click",()=>{navbar.classList.toggle("menu-open")}),document.querySelectorAll(".nav-links a").forEach(e=>{e.addEventListener("click",()=>{navbar.classList.remove("menu-open")})}));const sections=document.querySelectorAll("section[id]"),navItems=document.querySelectorAll(".nav-links a");function highlightNavOnScroll(){let e="",n=window.scrollY+100;sections.forEach(t=>{let a=t.offsetTop,l=t.offsetHeight,o=t.getAttribute("id");n>=a&&n<a+l&&(e=o)}),navItems.forEach(n=>{n.classList.remove("active"),n.getAttribute("href")==="#"+e&&n.classList.add("active")})}window.addEventListener("scroll",highlightNavOnScroll),window.addEventListener("load",highlightNavOnScroll);</script>
